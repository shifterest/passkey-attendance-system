# Infrastructure
REDIS_URL=redis://localhost:6379
DATABASE_URL=sqlite+pysqlite:///sqlite/attendance.db

# WebAuthn
WEB_ORIGIN=http://api.attendance.whatta.top
APP_ORIGIN=android:apk-key-hash:3mg2iB-JtknVTWAQS81rSIMVIWhj2OJ_PjUn-_33134
RP_ID=attendance.example.com
RP_NAME=Passkey Attendance System
REGISTRATION_PROTOCOL=pas

# Timeouts
CHALLENGE_TIMEOUT=180
LOGIN_TIMEOUT=1800
REGISTRATION_TIMEOUT=180

# Credential policy
MAX_ACTIVE_CREDENTIALS_PER_USER=1
DEVICE_PAYLOAD_MAX_AGE_MS=30000
MAX_CHECK_INS_PER_SESSION=3

# Rate limiting
AUTH_USER_RATELIMIT_MAX=5
AUTH_USER_RATELIMIT_WINDOW=60

# Bootstrap
BOOTSTRAP_ENABLED=false
BOOTSTRAP_TOKEN_TTL_SECONDS=300

# Timezone
SERVER_TIMEZONE=Asia/Manila

# Reverse proxy
TRUSTED_PROXY=